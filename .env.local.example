# Local development overrides.
# Copy to .env.local — it takes priority over .env
# .env.local is gitignored.

# --- Storage ---
# "local" = filesystem only (no S3), "s3" = S3 with local fallback
STORAGE_BACKEND=local

# --- Database ---
# Local PostgreSQL (uncomment and adjust)
# PGSQL_AIWORKFLOW_HOST=localhost
# PGSQL_AIWORKFLOW_PORT=5432
# PGSQL_AIWORKFLOW_DB=aiworkflow
# PGSQL_AIWORKFLOW_USER=aiworkflow_app
# PGSQL_AIWORKFLOW_PASSWORD=localpass
