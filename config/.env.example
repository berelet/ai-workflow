# AI Workflow — Local Configuration
# Copy to .env and fill in your values:
#   cp config/.env.example .env

# ─── Database (PostgreSQL) ───────────────────────────────────
PGSQL_AIWORKFLOW_HOST=localhost
PGSQL_AIWORKFLOW_PORT=5432
PGSQL_AIWORKFLOW_DB=aiworkflow
PGSQL_AIWORKFLOW_USER=aiworkflow_app
PGSQL_AIWORKFLOW_PASSWORD=your_password_here

# ─── JWT Secret ──────────────────────────────────────────────
# Auto-generated by the setup wizard. Leave empty for first run.
JWT_SECRET_KEY=

# ─── Dashboard Instance ─────────────────────────────────────
# Auto-generated by the setup wizard. Leave empty for first run.
DASHBOARD_UUID=

# ─── AI Provider ─────────────────────────────────────────────
# Which CLI to use for running agents
# Options: kiro-cli, claude
DEFAULT_CLI=kiro-cli

# Default model used by agents
# Kiro: auto (recommended), claude-sonnet-4-6-v1, claude-3-7-sonnet-v1
# Claude: sonnet (recommended), opus, haiku
DEFAULT_MODEL=auto

# ─── S3 Storage (optional) ───────────────────────────────────
# Used for binary artifacts (screenshots, images, audio)
# If not configured, files are stored locally
# S3_BUCKET=your-bucket-name
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT_URL=

# ─── Transcriber (optional) ─────────────────────────────────
# Absolute path to the transcriber directory
# TRANSCRIBER_DIR=/path/to/transcriber
